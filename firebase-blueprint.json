{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "A shared trip containing group expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "GroupExpense": {
      "title": "Group Expense",
      "description": "An expense shared by the group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["KRW", "TWD"] },
        "payer": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["item", "amount", "currency", "payer"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile containing their chosen nickname",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" }
      },
      "required": ["uid", "nickname"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Main trip document"
    },
    "/trips/{tripId}/groupExpenses": {
      "schema": "GroupExpense",
      "description": "Subcollection for group expenses"
    }
  }
}
